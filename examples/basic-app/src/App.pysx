def inc():
    alert("🔥 Works!")

def Item(name, price):
    return <div Class="card">
        {name} = {price * 2}
    </div>

def App():
    return <div Class="box">

        <h1>PYSX Full Test</h1>

        <Item name={"Apple"} price={10}/>
        <Item name={"Mango"} price={20}/>

        <button onClick={inc}>
            Click Test
        </button>

        {true && <p>Condition OK ✅</p>}

    </div>